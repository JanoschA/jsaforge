{
  "name": "jsa-forge-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "artifacts/api-server"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "npm run dev -w @jsa-forge/api-server",
    "typecheck": "tsc && npm run typecheck -w @jsa-forge/api-server",
    "build": "npm run typecheck && vite build && npm run build -w @jsa-forge/api-server",
    "preview": "npm run start",
    "start": "npm run start -w @jsa-forge/api-server"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
